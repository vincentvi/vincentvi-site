---
import '@fontsource-variable/cinzel';
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Antifragile — holographic model card"
  description="An experiment: a black card carrying a mental model, its letterforms catching white light as you move your cursor or tilt your phone."
>
  <p class="folio"><a href="/tinkering/">Tinkering</a> · experiment 001</p>
  <h1>Holographic model card</h1>
  <p class="lede">
    A mental model as an object. Move your cursor over the card — or tilt
    your phone — and the light crosses the letters.
  </p>

  <div class="stage" id="stage">
    <div class="holo-card" id="card">
      <span class="word" aria-hidden="true">ANTI<br />FRAGILE</span>
      <p class="subtitle">Beyond resilience — what gains from disorder.<br />A mental model, after Nassim Taleb.</p>
      <span class="sr-only">Black card reading Antifragile: beyond resilience — what gains from disorder. A mental model, after Nassim Taleb.</span>
      <span class="corner folio tl">Mental model</span>
      <span class="corner folio br">№ 001</span>
    </div>
  </div>

  <p class="center">
    <button id="motion-btn" class="motion" hidden>Enable tilt (motion sensor)</button>
  </p>

  <div class="prose">
    <h2>How it works</h2>
    <p>
      The card listens to your pointer (or the phone's gyroscope) and turns the
      position into four CSS variables: two rotation angles and a light
      coordinate. The reflection is a white radial gradient clipped inside the
      letterforms — the light exists only where there is ink. JavaScript only
      reports where the light source is; CSS does all the drawing.
    </p>
    <p>
      Honest notes: on iPhone, motion sensors need a permission tap (the button
      above appears there). And if your system has reduced motion switched on,
      the card politely holds still — as it should.
    </p>
  </div>
</BaseLayout>

<style>
  .lede { font-size: var(--step-1); color: var(--ink-muted); }
  .center { text-align: center; }

  .stage {
    display: grid;
    place-items: center;
    padding: 3.5rem 1rem;
    perspective: 900px;
    touch-action: none;
  }

  .holo-card {
    --rx: 0deg;
    --ry: 0deg;
    --mx: 50%;
    --my: 42%;
    position: relative;
    width: min(420px, 86vw);
    aspect-ratio: 5 / 7;
    border-radius: 12px;
    /* matte black, barely-there depth — lacquer, not disco */
    background:
      radial-gradient(140% 110% at 30% 8%, #191c25 0%, #14161d 55%, #101218 100%);
    box-shadow:
      0 24px 60px rgba(8, 10, 16, 0.5),
      inset 0 0 0 1px rgba(255, 255, 255, 0.05);
    display: grid;
    place-content: center;
    row-gap: 1.6rem;
    padding: 2rem;
    overflow: hidden;
    transform: rotateX(var(--rx)) rotateY(var(--ry));
    transition: transform 0.12s ease-out;
    will-change: transform;
  }
  /* a single hairline of light along the top edge — the one indulgence */
  .holo-card::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 8%, rgba(255,255,255,0.28) 50%, transparent 92%);
    pointer-events: none;
  }

  /* the words: white light clipped INSIDE the letterforms only.
     Base metal is dark graphite; the highlight is a white radial
     gradient centered on the light coordinate. No ink, no light. */
  .word {
    font-family: 'Cinzel Variable', 'Trajan Pro', Georgia, serif;
    font-weight: 560;
    font-size: clamp(2.6rem, 13vw, 4.2rem);
    letter-spacing: 0.06em;
    line-height: 1.12;
    text-align: center;
    background-image:
      radial-gradient(
        420px 420px at var(--mx) var(--my),
        #ffffff 0%,
        rgba(255, 255, 255, 0.82) 18%,
        rgba(160, 168, 190, 0.45) 42%,
        rgba(77, 83, 102, 0.92) 70%
      ),
      linear-gradient(#4d5366, #424859);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    user-select: none;
  }

  .subtitle {
    font-family: var(--font-body);
    font-size: 0.92rem;
    font-style: italic;
    line-height: 1.55;
    text-align: center;
    color: #8d93a8;
    margin: 0;
    max-width: 28ch;
    justify-self: center;
  }

  .corner { position: absolute; color: rgba(205, 210, 225, 0.38); }
  .tl { top: 1rem; left: 1.2rem; }
  .br { bottom: 1rem; right: 1.2rem; }

  .motion {
    cursor: pointer;
    font-family: var(--font-utility);
    font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--ink); background: none;
    border: 1px solid var(--ink); border-radius: 4px;
    padding: 0.7rem 1.3rem;
  }
  .motion:hover { border-color: var(--cloth); color: var(--cloth); }

  .sr-only {
    position: absolute; width: 1px; height: 1px;
    clip-path: inset(50%); overflow: hidden; white-space: nowrap;
  }

  .prose { margin-top: 3rem; }
</style>

<script>
  const stage = document.getElementById('stage');
  const card = document.getElementById('card');
  const btn = document.getElementById('motion-btn');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const MAX_TILT = 8; // degrees — quieter than before; luxury doesn't lunge

  function setLight(px, py) {
    card.style.setProperty('--ry', `${(px * 2 * MAX_TILT).toFixed(2)}deg`);
    card.style.setProperty('--rx', `${(-py * 2 * MAX_TILT).toFixed(2)}deg`);
    card.style.setProperty('--mx', `${(50 + px * 110).toFixed(1)}%`);
    card.style.setProperty('--my', `${(42 + py * 110).toFixed(1)}%`);
  }

  function reset() {
    card.style.setProperty('--rx', '0deg');
    card.style.setProperty('--ry', '0deg');
    card.style.setProperty('--mx', '50%');
    card.style.setProperty('--my', '42%');
  }

  if (!reduced && stage && card) {
    stage.addEventListener('pointermove', (e) => {
      const r = card.getBoundingClientRect();
      const px = (e.clientX - r.left) / r.width - 0.5;
      const py = (e.clientY - r.top) / r.height - 0.5;
      setLight(Math.max(-0.5, Math.min(0.5, px)), Math.max(-0.5, Math.min(0.5, py)));
    });
    stage.addEventListener('pointerleave', reset);

    const hasOrientation = 'DeviceOrientationEvent' in window;
    const needsPermission =
      hasOrientation &&
      typeof window.DeviceOrientationEvent.requestPermission === 'function';

    function startGyro() {
      window.addEventListener('deviceorientation', (e) => {
        if (e.beta == null || e.gamma == null) return;
        const px = Math.max(-0.5, Math.min(0.5, e.gamma / 60));
        const py = Math.max(-0.5, Math.min(0.5, (e.beta - 40) / 60));
        setLight(px, py);
      });
    }

    if (needsPermission && btn) {
      btn.hidden = false;
      btn.addEventListener('click', async () => {
        try {
          const state = await window.DeviceOrientationEvent.requestPermission();
          if (state === 'granted') { startGyro(); btn.hidden = true; }
        } catch { /* declined — pointer still works */ }
      });
    } else if (hasOrientation) {
      startGyro();
    }
  }
</script>
