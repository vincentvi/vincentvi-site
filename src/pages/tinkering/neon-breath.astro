---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { WEB3FORMS_ACCESS_KEY } from '../../config';

// ------------------------------------------------------------------
// THE ARCHIVE. One entry per sign — add a sign by adding an object
// here, nothing else changes. The photos below are generated SVG
// placeholders (public/signs/sample-*.svg); swap `photo` for the real
// image path. Coordinates come from Google Maps: right-click the
// storefront, first menu item copies "lat, lng".
//
// Optional: `spottedBy: 'Mai N.'` credits a visitor who nominated the
// sign through the form at the bottom of the page.
//
// ⚠ SAMPLE DATA — names/addresses/coords are stand-ins for review.
// ------------------------------------------------------------------
const STYLE_TAGS = [
  'blackletter', 'brush-script', 'condensed', 'display', 'handwritten',
  'monoline', 'rounded', 'sans', 'script', 'serif', 'slab',
];

interface Sign {
  num: string;
  title: string;
  photo: string;
  address: string;
  lat: number;
  lng: number;
  tags: string[];
  note: string;
  /** credit for a visitor who nominated this sign */
  spottedBy?: string;
}

const signs: Sign[] = [
  {
    num: '№ 001',
    title: 'Phở Hòa',
    photo: '/signs/sample-01.svg',
    address: '260C Pasteur, Quận 3',
    lat: 10.78337, lng: 106.68854,
    tags: ['script'],
    note: 'Steam-era script over the phở counter — the loops still carry the hand that drew them.',
  },
  {
    num: '№ 002',
    title: 'Bánh mì Huỳnh Hoa',
    photo: '/signs/sample-02.svg',
    address: '26 Lê Thị Riêng, Quận 1',
    lat: 10.77143, lng: 106.69175,
    tags: ['sans', 'condensed'],
    note: 'Condensed caps doing crowd control — the queue reads it before the smell arrives.',
  },
  {
    num: '№ 003',
    title: 'Cà phê Cheo Leo',
    photo: '/signs/sample-03.svg',
    address: '36/7B Nguyễn Thiện Thuật, Quận 3',
    lat: 10.77147, lng: 106.68159,
    tags: ['handwritten'],
    note: 'A hand that never met a grid — painted once, retouched for decades.',
  },
  {
    num: '№ 004',
    title: 'Kem Bạch Đằng',
    photo: '/signs/sample-04.svg',
    address: '26–28 Lê Lợi, Quận 1',
    lat: 10.77345, lng: 106.70142,
    tags: ['display', 'rounded'],
    note: 'Rounded terminals for ice cream — letterforms licked soft.',
  },
  {
    num: '№ 005',
    title: 'Nhà may Mỹ Hạnh',
    photo: '/signs/sample-05.svg',
    address: '91 Lý Tự Trọng, Quận 1',
    lat: 10.77266, lng: 106.69769,
    tags: ['brush-script'],
    note: 'A tailor’s flourish — the brush stroke is already a fitting.',
  },
  {
    num: '№ 006',
    title: 'Saigon Hotel',
    photo: '/signs/sample-06.svg',
    address: '41–47 Đông Du, Quận 1',
    lat: 10.77607, lng: 106.70431,
    tags: ['slab', 'serif'],
    note: 'Slab serifs holding up the façade since before the paint mattered.',
  },
];

const tagCount = (t: string) => signs.filter((s) => s.tags.includes(t)).length;
const mapsUrl = (s: Sign) =>
  `https://www.google.com/maps/search/?api=1&query=${s.lat},${s.lng}`;

// styles with no specimen yet — the archive asks for these by name
const missing = STYLE_TAGS.filter((t) => tagCount(t) === 0);

// minimal payload for the client script
const SIGNS_JS = signs.map((s) => ({ lat: s.lat, lng: s.lng, tags: s.tags, title: s.title }));
---
<BaseLayout
  title="Neon Breath"
  description="Neon Breath — a specimen archive of neon storefront signs. Browse the carousel, filter by letterform style, find each sign on the map."
>
  <p class="folio crumb"><a href="/tinkering/">Tinkering</a> · experiment 004</p>
  <h1>Neon Breath</h1>
  <p class="lede">
    A specimen archive of storefront neon, cataloged sign by sign.
    Browse with the arrows, filter by letterform style —
    every specimen links to the exact corner it glows on.
  </p>

  <div class="filter" role="group" aria-label="Filter by letterform style">
    <span class="folio filter-label">Style ({STYLE_TAGS.length})</span>
    {STYLE_TAGS.map((t) => (
      <button class="chip" data-tag={t} disabled={tagCount(t) === 0}>
        {t} <span class="count">({tagCount(t)})</span>
      </button>
    ))}
  </div>

  <div class="stage">
    <div class="viewport">
      {signs.map((s, i) => (
        <figure class={`shot${i === 0 ? ' active' : ''}`} data-i={i}>
          <img src={s.photo} alt={`Neon sign of ${s.title} — placeholder illustration`} loading={i === 0 ? 'eager' : 'lazy'} />
        </figure>
      ))}
      <button class="nav prev" id="prev" aria-label="Previous sign">‹</button>
      <button class="nav next" id="next" aria-label="Next sign">›</button>
    </div>

    <aside class="panel">
      {signs.map((s, i) => (
        <div class={`spec${i === 0 ? ' active' : ''}`} data-i={i}>
          <p class="folio spec-num">Specimen · {s.num}</p>
          <h2>{s.title}</h2>
          <p class="note">{s.note}</p>
          <p class="spec-tags">
            {s.tags.map((t) => <span class="tag">{t}</span>)}
          </p>
          <p class="address">
            <a href={mapsUrl(s)} target="_blank" rel="noopener">
              {s.address} ↗
            </a>
          </p>
          {s.spottedBy && <p class="folio spotted">Spotted by {s.spottedBy}</p>}
        </div>
      ))}
      <div id="minimap" aria-label="Map location of the current sign"></div>
    </aside>

    <div class="viewer-foot">
      <div class="thumbs" id="thumbs">
        {signs.map((s, i) => (
          <button class={`thumb${i === 0 ? ' current' : ''}`} data-i={i} aria-label={`Show ${s.title}`}>
            <img src={s.photo} alt="" loading="lazy" />
          </button>
        ))}
      </div>
    </div>

    <p class="folio map-hint">pin = this sign · link opens Google Maps</p>
  </div>

  <section class="nominate">
    <p class="folio">Nominate a sign</p>
    <h2>Know a sign worth collecting?</h2>
    <p class="nom-lede">
      Don't send a photo — send a <em>place</em>. Tell me the store and where it
      stands, and I'll go photograph it myself. If it makes the archive, your
      name goes on the specimen.
    </p>

    {missing.length > 0 && (
      <p class="wanted">
        <span class="folio wanted-label">Still missing</span>
        {missing.map((t) => <span class="tag wanted-tag">{t}</span>)}
        <span class="wanted-tail">
          — no specimen in the archive yet. Know one? That's the sign I most want.
        </span>
      </p>
    )}

    <form action="https://api.web3forms.com/submit" method="POST">
      <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
      <input type="hidden" name="subject" value="Neon Breath — sign nomination" />
      <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />

      <label>
        The store or place
        <input type="text" name="store" required placeholder="Phở Hòa" />
      </label>

      <label>
        Where it stands
        <input
          type="text"
          name="location"
          required
          placeholder="Street address, or paste a Google Maps link"
        />
      </label>

      <label>
        What makes the lettering worth the trip <span class="opt">(optional)</span>
        <textarea
          name="why"
          rows="4"
          placeholder="Hand-painted script, glowing since the 60s, still repainted every Tết…"
        ></textarea>
      </label>

      <div class="row">
        <label>
          Your name <span class="opt">(for the credit line)</span>
          <input type="text" name="name" autocomplete="name" placeholder="Mai N." />
        </label>
        <label>
          Email <span class="opt">(optional — only to tell you it's up)</span>
          <input type="email" name="email" autocomplete="email" />
        </label>
      </div>

      <button type="submit">Send the nomination</button>
    </form>
  </section>
</BaseLayout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script is:inline define:vars={{ SIGNS: SIGNS_JS }}>
  const shots = [...document.querySelectorAll('.shot')];
  const thumbs = [...document.querySelectorAll('.thumb')];
  const specs = [...document.querySelectorAll('.spec')];
  const chips = [...document.querySelectorAll('.chip')];

  let activeTag = null;              // null = all
  let visible = SIGNS.map((_, i) => i);
  let current = 0;                   // index into SIGNS, always ∈ visible

  // --- mini map -----------------------------------------------------
  let map = null, pin = null;
  if (window.L) {
    map = L.map('minimap', {
      zoomControl: true, scrollWheelZoom: false, attributionControl: true,
    }).setView([SIGNS[0].lat, SIGNS[0].lng], 16);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; OpenStreetMap &copy; CARTO', subdomains: 'abcd', maxZoom: 19,
    }).addTo(map);
    pin = L.marker([SIGNS[0].lat, SIGNS[0].lng], {
      icon: L.divIcon({ className: 'neon-pin', iconSize: [14, 14] }),
    }).addTo(map);
  }

  // --- render -------------------------------------------------------
  function render() {
    shots.forEach((el, i) => el.classList.toggle('active', i === current));
    specs.forEach((el, i) => el.classList.toggle('active', i === current));
    thumbs.forEach((el, i) => {
      el.classList.toggle('current', i === current);
      el.style.display = visible.includes(i) ? '' : 'none';
    });
    if (map) {
      const s = SIGNS[current];
      pin.setLatLng([s.lat, s.lng]);
      map.panTo([s.lat, s.lng], { animate: true });
    }
  }

  function step(dir) {
    const pos = visible.indexOf(current);
    current = visible[(pos + dir + visible.length) % visible.length];
    render();
  }

  // --- filter -------------------------------------------------------
  chips.forEach((chip) => chip.addEventListener('click', () => {
    const tag = chip.dataset.tag;
    activeTag = activeTag === tag ? null : tag;
    chips.forEach((c) => c.classList.toggle('active', c.dataset.tag === activeTag));
    visible = SIGNS.map((_, i) => i)
      .filter((i) => !activeTag || SIGNS[i].tags.includes(activeTag));
    if (!visible.includes(current)) current = visible[0];
    render();
  }));

  // --- controls -----------------------------------------------------
  document.getElementById('prev').addEventListener('click', () => step(-1));
  document.getElementById('next').addEventListener('click', () => step(1));
  thumbs.forEach((el, i) => el.addEventListener('click', () => { current = i; render(); }));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') { e.preventDefault(); step(-1); }
    if (e.key === 'ArrowRight') { e.preventDefault(); step(1); }
  });
</script>

<style>
  /* Dark & green room for this page only — same token-level trick as
     five-voices: html:root (0,1,1) out-ranks global.css's :root.
     Accent = spring green #A7F175; hairlines are the same green at
     low alpha so every border reads green without shouting. */
  :global(html:root) {
    --neon: #a7f175;
    --paper: #111318;
    --ink: #e6e4dc;
    --ink-muted: #9b9a90;
    --hairline: rgba(167, 241, 117, 0.28);
    --cloth: var(--neon);
    --foil: var(--neon);
  }

  .crumb { max-width: none; }
  .lede { font-size: var(--step-1); color: var(--ink-muted); max-width: 46ch; }

  /* ---- style filter ---- */
  .filter {
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem;
    margin: 2.5rem 0 2rem; padding-top: 1.5rem;
    border-top: 1px solid var(--hairline);
  }
  .filter-label { margin-right: 0.5rem; }
  .chip {
    cursor: pointer; background: none;
    font-family: var(--font-utility); font-size: 0.72rem; letter-spacing: 0.08em;
    border: 1px solid var(--hairline); border-radius: 999px;
    padding: 0.32rem 0.8rem; color: var(--ink-muted);
    transition: border-color 0.25s ease, color 0.25s ease;
  }
  .chip .count { opacity: 0.55; }
  .chip:hover:not(:disabled) { border-color: var(--foil); color: var(--foil); }
  .chip.active { border-color: var(--foil); color: var(--ink); background: rgba(167, 241, 117, 0.12); }
  .chip:disabled { opacity: 0.35; cursor: default; }

  /* ---- stage ---- */
  /* 2×2 grid. Row 1 is the aligned pair — photo frame / specimen+map —
     both stretched to the same height, with the map pinned to the cell
     bottom, so frame and map share one bottom edge. Row 2 holds the
     compact footers (thumbs+keys / map hint), outside the alignment. */
  .stage {
    display: grid; grid-template-columns: minmax(0, 1.55fr) minmax(280px, 1fr);
    column-gap: clamp(1.5rem, 4vw, 3rem); row-gap: 0.75rem;
    align-items: stretch;
  }
  .viewport { grid-column: 1; grid-row: 1; }
  .panel { grid-column: 2; grid-row: 1; }
  .viewer-foot { grid-column: 1; grid-row: 2; }
  .map-hint { grid-column: 2; grid-row: 2; }
  @media (max-width: 820px) {
    .stage { grid-template-columns: 1fr; }
    .viewport, .panel, .viewer-foot, .map-hint { grid-column: 1; grid-row: auto; }
    .viewport { order: 1; } .viewer-foot { order: 2; }
    .panel { order: 3; } .map-hint { order: 4; }
  }

  /* No aspect-ratio on desktop: height comes from the grid row (the
     panel+map column), and aspect-ratio would transfer that height
     back into width, overflowing the column. Mobile has no row to
     inherit from, so the ratio applies there instead. */
  .viewport {
    position: relative; overflow: hidden; min-height: 380px;
    border: 1px solid #2a3654; background: #05070c;
  }
  @media (max-width: 820px) {
    /* padding-ratio instead of aspect-ratio: every child of the frame
       is absolutely positioned (zero content height), and WebKit drops
       the aspect-ratio height transfer on grid items in that case —
       the frame collapses to nothing on phones. The ::before spacer
       guarantees 4:3 from the width in every engine. */
    .viewport { min-height: 0; }
    .viewport::before { content: ''; display: block; padding-top: 75%; }
  }
  .shot {
    position: absolute; inset: 0; margin: 0;
    opacity: 0; transform: scale(1.015);
    transition: opacity 0.45s ease, transform 0.45s ease;
    pointer-events: none;
  }
  .shot.active { opacity: 1; transform: none; }
  .shot img { width: 100%; height: 100%; object-fit: cover; }

  .nav {
    position: absolute; top: 50%; transform: translateY(-50%);
    width: 2.5rem; height: 2.5rem; border-radius: 50%;
    cursor: pointer; font-size: 1.3rem; line-height: 1;
    color: var(--ink); background: rgba(17, 19, 24, 0.65);
    border: 1px solid var(--hairline); backdrop-filter: blur(4px);
    transition: border-color 0.25s ease, color 0.25s ease;
  }
  .nav:hover { border-color: var(--foil); color: var(--foil); }
  .prev { left: 0.75rem; } .next { right: 0.75rem; }

  .thumbs { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .thumb {
    cursor: pointer; padding: 0; width: 4.5rem; aspect-ratio: 4 / 3;
    border: 1px solid var(--hairline); background: #05070c;
    opacity: 0.45; transition: opacity 0.25s ease, border-color 0.25s ease;
  }
  .thumb img { width: 100%; height: 100%; object-fit: cover; }
  .thumb.current { opacity: 1; border-color: var(--foil); }
  .thumb:hover { opacity: 1; }

  /* ---- specimen panel ---- */
  .panel {
    border-top: 1px solid var(--hairline); padding-top: 1.25rem;
    display: flex; flex-direction: column;
  }
  .spec { display: none; }
  .spec.active { display: block; animation: fade 0.45s ease; }
  @keyframes fade { from { opacity: 0; } to { opacity: 1; } }

  .spec-num { margin: 0 0 0.6rem; }
  .spec h2 { margin: 0 0 0.5rem; font-size: var(--step-2); }
  .note {
    font-style: italic; color: var(--ink-muted);
    margin: 0 0 1rem; max-width: 40ch;
  }
  .spec-tags { margin: 0 0 1rem; display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .tag {
    font-family: var(--font-utility); font-size: 0.68rem; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--foil);
    border: 1px solid var(--hairline); border-radius: 999px; padding: 0.22rem 0.65rem;
  }
  .address { margin: 0 0 1.25rem; font-family: var(--font-utility); font-size: 0.8rem; }
  .address a { text-decoration-style: dotted; }

  .spotted { margin: 0.75rem 0 0; }

  #minimap {
    height: 340px; margin-top: auto; /* pin to the aligned bottom edge */
    border: 1px solid var(--hairline);
    background: #05070c;
  }
  .map-hint { margin: 0; }

  /* ---- nominate a sign ---- */
  .nominate {
    margin-top: 4.5rem; padding-top: 2.5rem;
    border-top: 1px solid var(--hairline);
  }
  .nominate h2 { margin: 0.4rem 0 0.75rem; }
  .nom-lede { color: var(--ink-muted); font-size: var(--step-1); max-width: 46ch; }

  /* the archive names the gaps in itself — generated from tag counts */
  .wanted {
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem;
    max-width: 52ch; margin: 1.75rem 0 0;
    padding: 1rem 1.25rem;
    border: 1px solid var(--hairline); border-radius: 4px;
    background: rgba(167, 241, 117, 0.05);
  }
  .wanted-label { margin-right: 0.15rem; }
  .wanted-tag { color: var(--neon); }
  .wanted-tail { color: var(--ink-muted); font-style: italic; }

  .nominate form { display: grid; gap: 1.25rem; max-width: 40rem; margin-top: 2rem; }
  .nominate label {
    display: grid; gap: 0.4rem;
    font-family: var(--font-utility); font-size: 0.74rem; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--ink-muted);
  }
  .opt { text-transform: none; letter-spacing: 0.02em; opacity: 0.6; }
  .row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  @media (max-width: 620px) { .row { grid-template-columns: 1fr; } }

  .nominate input[type='text'],
  .nominate input[type='email'],
  .nominate textarea {
    font-family: var(--font-body); font-size: var(--step-0); color: var(--ink);
    padding: 0.7rem 0.85rem; border-radius: 4px;
    border: 1px solid var(--hairline); background: rgba(5, 7, 12, 0.6);
  }
  .nominate ::placeholder { color: var(--ink-muted); opacity: 0.55; }
  .nominate input:focus, .nominate textarea:focus {
    border-color: var(--neon); outline: none;
  }
  .nominate button {
    justify-self: start; cursor: pointer;
    font-family: var(--font-utility); font-size: 0.82rem; letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #0d120c; background: var(--neon);
    border: 0; border-radius: 4px; padding: 0.85rem 1.6rem;
    transition: filter 0.25s ease;
  }
  .nominate button:hover { filter: brightness(1.12); }
  .hidden { display: none; }

  /* leaflet lives outside Astro's scope */
  :global(#minimap .leaflet-container) { background: #05070c; }
  :global(.neon-pin) {
    border-radius: 50%; background: var(--neon);
    box-shadow: 0 0 0 3px rgba(167, 241, 117, 0.25), 0 0 16px 5px rgba(167, 241, 117, 0.6);
  }
  :global(#minimap .leaflet-control-zoom) {
    border: 1px solid var(--hairline);
  }
  :global(#minimap .leaflet-control-zoom a) {
    background: rgba(17, 19, 24, 0.85); color: var(--ink);
    border-bottom: 1px solid var(--hairline);
    transition: color 0.25s ease;
  }
  :global(#minimap .leaflet-control-zoom a:last-child) { border-bottom: 0; }
  :global(#minimap .leaflet-control-zoom a:hover) { color: var(--neon); background: rgba(17, 19, 24, 0.95); }
  :global(#minimap .leaflet-control-zoom a.leaflet-disabled) { opacity: 0.4; color: var(--ink-muted); }
  :global(#minimap .leaflet-control-attribution) {
    background: rgba(17, 19, 24, 0.7); color: var(--ink-muted); font-size: 9px;
  }
  :global(#minimap .leaflet-control-attribution a) { color: var(--ink-muted); }
</style>
