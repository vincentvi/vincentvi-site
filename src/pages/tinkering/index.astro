---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SandGrain from '../../components/SandGrain.astro';

const experiments = [
  {
    href: '/tinkering/variable-font/',
    title: 'Variable font playground',
    summary: 'One typeface, five live dials. Drag sliders to morph the axes of Fraunces across "Gradatim Ferociter".',
    tags: 'CSS · JS · variable fonts',
    thumb: '/images/tinkering/variable-font.svg',
    alt: 'Placeholder sketch: a large letter G beside three axis sliders labelled wght, opsz, SOFT.',
  },
  {
    href: '/tinkering/holo-card/',
    title: 'Holographic model cards',
    summary: 'A growing deck of mental models as dark cards — browse the carousel, watch light cross the letterforms, flip a card for its definition.',
    tags: 'CSS · JS · variable fonts',
    thumb: '/images/tinkering/holo-card.svg',
    alt: 'Placeholder sketch: a dark playing card with a band of light crossing a large letter A.',
  },
  {
    href: '/tinkering/six-tones/',
    title: 'Six tones, one letter',
    summary: 'An explorable infographic of Vietnamese diacritics — build a syllable from a vowel, a quality mark and one of six tones, watch the stack assemble, then see what a font without a Vietnamese subset does to it.',
    tags: 'JS · Unicode · type design · explorable',
    thumb: '/images/tinkering/six-tones.svg',
    alt: 'Placeholder sketch: the vowel a with six tone-marked variants orbiting it.',
  },
  {
    href: '/tinkering/compounding/',
    title: 'Step by step, ferociously',
    summary: 'An explorable note on compounding — drag the numbers inside the sentence and watch the curve, and a letter of type, grow with them until the letter no longer fits the page.',
    tags: 'JS · dataviz · explorable · type',
    thumb: '/images/tinkering/compounding.svg',
    alt: 'Placeholder sketch: an exponential curve with the letter G growing along it.',
  },
  {
    href: '/tinkering/neon-breath/',
    title: 'Neon Breath',
    summary: 'A specimen archive of storefront neon — browse the carousel, filter by letterform style (brush script, slab, monoline…), and find each sign on the map it glows on.',
    tags: 'CSS · JS · lettering · maps',
    thumb: '/images/tinkering/neon-breath.svg',
    alt: 'Placeholder sketch: a glowing neon script word in a storefront frame, with a map pin.',
  },
  {
    href: '/tinkering/five-voices/',
    title: 'One line, five voices',
    summary: 'Type your own line and watch the same words wear five typographic voices — whisper, declaration, conversation, terminal, play — plus one empty frame where hand lettering begins.',
    tags: 'CSS · JS · variable fonts',
    thumb: '/images/tinkering/five-voices.svg',
    alt: 'Placeholder sketch: the word voice set five ways, above an empty dashed frame.',
  },
  {
    href: '/tinkering/curtain/',
    title: 'The character curtain',
    summary: 'A bead curtain woven from strands of type — brush your cursor through it and the glyphs swing with your movement, flaring neon green in its wake before they settle back.',
    tags: 'JS · canvas · physics · type',
    thumb: '/images/tinkering/curtain.svg',
    alt: 'Placeholder sketch: a dense field of monospace characters, lit neon green where a cursor ripples through.',
  },
];
---
<BaseLayout
  title="Tinkering"
  description="Experiments and small studies in typography, CSS, animation, and interactive design — the workbench next to the portfolio."
>
  <SandGrain />
  <p class="folio">Tinkering · the workbench</p>
  <h1>Exper<span class="eye">i</span>ments</h1>
  <p class="lede">
    My letter playground, come play with me or just say hi! These are not
    from client work, just my tinkerings while I cannot find a place provide
    these all yet. Some become techniques; some just teach me something.
  </p>

  <ul class="experiments">
    {experiments.map((x, i) => (
      <li>
        <a class="card" href={x.href}>
          <figure>
            <img src={x.thumb} alt={x.alt} width="800" height="600" loading={i < 2 ? 'eager' : 'lazy'} />
          </figure>
          <p class="folio no">№ {String(i + 1).padStart(2, '0')}</p>
          <h2>{x.title}</h2>
          <p class="summary">{x.summary}</p>
          <p class="folio">{x.tags}</p>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  /* Dark room for this page only — token-level, so header, footer, and every
     .folio inherit the theme without per-element overrides. Must sit on
     html:root (0,1,1) to out-rank global.css's :root (0,1,0); a bare html
     type selector loses that fight regardless of load order. Matches the
     other Tinkering pages (five-voices, neon-breath, six-tones…). */
  :global(html:root) {
    --paper: #111318;
    --ink: #e6e4dc;
    --ink-muted: #9b9a90;
    --hairline: #262b38;
    --cloth: #8fb0e0;
    --foil: #6f96c4;
    --highlight: var(--highlight-fill);  /* the dark ground takes the spring green */

    /* the sand needs to flip light to read on the dark ground */
    --grain-rgb: 165 197 236;
  }

  /* the title runs green, with a single bright-yellow, haloed "i" */
  h1 { color: var(--highlight); }
  h1 .eye {
    color: #fff1b8;   /* brighter, less saturated — a pale creamy yellow */
    text-shadow:
      0 0 8px rgba(255, 225, 77, 0.85),
      0 0 22px rgba(255, 210, 60, 0.5),
      0 0 44px rgba(255, 200, 40, 0.3);
  }

  .lede { font-size: var(--step-1); color: var(--ink-muted); }

  /* The pinboard: staggered columns of index cards, each pinned at its
     own slight angle. Playfulness lives in the geometry — the palette stays
     paper-and-ink. */
  .experiments {
    list-style: none;
    padding: 0 0 2rem;
    margin-top: 3rem;
    display: grid;
    gap: 2.75rem 2.5rem;
  }

  /* the page went dark, but the cards stay on light paper — re-establish the
     light token set locally so each card's text, borders and folio marks read
     correctly on paper (the mirror of the page-level dark block above) */
  .card {
    --paper: #fbfbf8;
    --ink: #1b1b18;
    --ink-muted: #56564e;
    --hairline: #e4e3da;
    --foil: hwb(0 9% 91%);
    --highlight: #417a04;        /* dark green, legible on the light card */

    display: block;
    text-decoration: none;
    color: var(--ink);
    background: var(--paper);
    border: 1px solid var(--hairline);
    padding: 1.1rem 1.1rem 1.4rem;
    box-shadow: 0 1px 2px rgb(27 27 24 / 5%), 0 10px 28px rgb(27 27 24 / 7%);
    transform: rotate(var(--tilt, 0deg));
    transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
  }

  /* each card gets its own lean — like things pinned by hand */
  li:nth-child(6n + 1) { --tilt: -1.1deg; }
  li:nth-child(6n + 2) { --tilt: 0.9deg; }
  li:nth-child(6n + 3) { --tilt: 0.6deg; }
  li:nth-child(6n + 4) { --tilt: -0.8deg; }
  li:nth-child(6n + 5) { --tilt: 1.2deg; }
  li:nth-child(6n + 6) { --tilt: -0.5deg; }

  .card figure { position: relative; margin: 0 0 1.1rem; }
  .card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border: 1px solid var(--hairline);
  }
  /* washi tape holding the photo down */
  .card figure::after {
    content: '';
    position: absolute;
    top: -0.7rem;
    left: 50%;
    width: 6.5rem;
    height: 1.5rem;
    transform: translateX(-50%) rotate(-2.5deg);
    background: color-mix(in srgb, var(--highlight-fill) 55%, transparent);
    border: 1px solid rgb(27 27 24 / 6%);
  }

  .no { margin: 0 0 0.35rem; color: var(--highlight); }
  .card h2 { margin: 0 0 0.4rem; font-size: var(--step-1); }
  .card .summary { margin: 0 0 0.7rem; color: var(--ink-muted); }
  .card > .folio:last-child { margin: 0; }

  @media (hover: hover) {
    .card:hover {
      transform: rotate(0deg) translateY(-6px);
      border-color: var(--foil);
      box-shadow: 0 2px 4px rgb(27 27 24 / 6%), 0 18px 40px rgb(27 27 24 / 12%);
    }
  }

  /* two columns on medium screens, right one hanging lower — a board, not a table */
  @media (min-width: 48rem) and (max-width: 71.99rem) {
    .experiments { grid-template-columns: 1fr 1fr; }
    li:nth-child(even) { margin-top: 3rem; }
  }

  /* three columns on wide screens — smaller cards, each column at its own
     hanging height so the board still reads hand-pinned, not gridded */
  @media (min-width: 72rem) {
    .experiments {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 2.5rem 2rem;
    }
    li:nth-child(3n + 2) { margin-top: 3rem; }
    li:nth-child(3n) { margin-top: 1.5rem; }
  }
</style>
