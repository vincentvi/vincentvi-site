---
import '@fontsource-variable/recursive/full.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Variable font playground"
  description="An interactive instrument: drag the sliders to morph the live axes of Recursive — weight, casual, mono, slant, and cursive — across the phrase Gradatim Ferociter."
>
  <p class="folio crumb"><a href="/tinkering/">Tinkering</a> · experiment 002</p>
  <h1>Variable font playground</h1>
  <p class="lede">
    One typeface, five live dials. Drag the sliders and watch the letterforms
    change shape in real time — this is what "variable font" actually means.
  </p>

  <div class="play-head">
    <p class="folio type-legend">✎ Click the text below and type your own</p>
    <div class="share" aria-label="Share this playground">
      <span class="folio share-label">Share</span>
      <button class="share-btn folio" data-net="x" type="button">X</button>
      <button class="share-btn folio" data-net="linkedin" type="button">LinkedIn</button>
      <button class="share-btn folio" data-net="copy" type="button" id="copy-btn">Copy link</button>
      <button class="share-btn folio" data-net="native" type="button" id="native-share" hidden>More…</button>
    </div>
  </div>

  <div class="panel">
    <div class="specimen" id="specimen" contenteditable="true" role="textbox"
         aria-label="Editable type specimen — type your own text"
         spellcheck="false">Gradatim Ferociter</div>
  </div>

  <div class="controls">
    <label>
      <span class="row"><span class="folio">Weight</span><output id="out-wght">400</output></span>
      <input type="range" id="wght" min="300" max="1000" step="1" value="400" />
    </label>
    <label>
      <span class="row"><span class="folio">Casual <span class="tag">the soft one</span></span><output id="out-casl">0</output></span>
      <input type="range" id="casl" min="0" max="100" step="1" value="0" />
      <span class="hint folio">Linear (crisp, technical) → Casual (soft, hand-drawn, rounded terminals). The most character-changing dial here.</span>
    </label>
    <label>
      <span class="row"><span class="folio">Mono</span><output id="out-mono">0</output></span>
      <input type="range" id="mono" min="0" max="100" step="1" value="0" />
      <span class="hint folio">Proportional (natural spacing) → Monospace (fixed, code-like widths).</span>
    </label>
    <label>
      <span class="row"><span class="folio">Slant</span><output id="out-slnt">0</output></span>
      <input type="range" id="slnt" min="-15" max="0" step="1" value="0" />
    </label>
    <label class="curs-row folio">
      Cursive <input type="checkbox" id="crsv" />
      <span class="hint folio" style="margin-left:0.5rem;">true italic letterforms at slant</span>
    </label>

    <div class="presets">
      <span class="folio">Jump to:</span>
      <button type="button" data-w="300" data-c="0" data-m="0" data-s="0" class="preset folio">Clean text</button>
      <button type="button" data-w="640" data-c="100" data-m="0" data-s="0" class="preset folio">Handwritten</button>
      <button type="button" data-w="500" data-c="0" data-m="100" data-s="0" class="preset folio">Code</button>
      <button type="button" data-w="900" data-c="30" data-m="0" data-s="-14" class="preset folio">Display slant</button>
    </div>
    <button id="reset" class="reset folio">Reset</button>
  </div>

  <div class="prose">
    <h2>How it works</h2>
    <p>
      Recursive is a <em>variable font</em>: instead of shipping separate files
      for bold, light, and italic, it ships one file containing a continuous
      space of possibilities along named axes. Each control writes to
      <code>font-variation-settings</code>, and the browser redraws the outlines
      instantly. No images, no separate files — the letters are re-interpolated
      live.
    </p>
    <p>
      Recursive is built for exactly this kind of play. <strong>Casual</strong>
      morphs the whole personality from crisp and technical to soft and
      hand-drawn — it's the "softness" axis, done dramatically. <strong>Mono</strong>
      snaps the spacing toward code-like fixed widths, <strong>weight</strong>
      and <strong>slant</strong> do the familiar work, and <strong>cursive</strong>
      swaps in true flowing italic forms. "Gradatim ferociter" — step by step,
      ferociously.
    </p>
  </div>
</BaseLayout>

<style>
  /* Dark room for this page only — token-level, so header, footer and every
     .folio inherit the theme without per-element overrides. Must sit on
     html:root (0,1,1) to out-rank global.css's :root (0,1,0). Matches the
     other Tinkering pages (five-voices, neon-breath, six-tones…). */
  :global(html:root) {
    --paper: #111318;
    --ink: #e6e4dc;
    --ink-muted: #9b9a90;
    --hairline: #262b38;
    --cloth: #8fb0e0;
    --foil: #6f96c4;
    --highlight: var(--highlight-fill);  /* the dark ground takes the spring green */
  }

  .crumb { text-align: center; max-width: none; }
  h1 { text-align: center; }
  .lede {
    font-size: var(--step-1); color: var(--ink-muted);
    text-align: center; max-width: 46ch; margin-inline: auto;
  }

  .play-head {
    display: flex; align-items: center; justify-content: space-between;
    gap: 1rem; flex-wrap: wrap;
    max-width: 100%; margin: 0 0 0.7rem;
  }
  .type-legend {
    margin: 0;
    color: var(--ink-muted);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
  }
  .share { display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem; }
  .share-label { color: var(--ink-muted); margin-right: 0.15rem; }
  .share-btn {
    cursor: pointer; background: none;
    border: 1px solid var(--hairline); border-radius: 4px;
    padding: 0.35rem 0.75rem; color: var(--ink-muted);
    transition: border-color 0.25s ease, color 0.25s ease;
  }
  .share-btn:hover { border-color: var(--foil); color: var(--foil); }
  @media (max-width: 560px) {
    .play-head { justify-content: center; }
  }

  .panel {
    background: radial-gradient(120% 130% at 50% 0%, #191c25 0%, #14161d 60%, #101218 100%);
    border-radius: 12px;
    padding: clamp(2.5rem, 7vw, 5rem) 1.5rem;
    margin: 2rem 0 1.75rem;
    display: grid; place-items: center; min-height: 40vh;
  }
  .specimen {
    font-family: 'Recursive Variable', system-ui, sans-serif;
    font-variation-settings: 'wght' 400, 'CASL' 0, 'MONO' 0, 'slnt' 0, 'CRSV' 0;
    font-size: clamp(2.6rem, 11vw, 5.5rem);
    line-height: 1.08; text-align: center; color: #e9ebf2;
    letter-spacing: -0.01em;
    will-change: font-variation-settings;
    outline: none;
    caret-color: var(--foil);
    max-width: 100%;
    word-break: break-word;
    cursor: text;
  }
  .specimen:empty::before {
    content: 'Type here…';
    color: #4a4f5e;
  }
  .specimen:focus { outline: none; }
  .panel:focus-within { box-shadow: inset 0 0 0 1px rgba(87,128,172,0.4); }

  .controls { display: grid; gap: 1.6rem; max-width: 34rem; margin-inline: auto; }
  label { display: grid; gap: 0.5rem; }
  .row { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; }
  .hint { text-align: center; }
  output { font-family: var(--font-utility); font-size: 0.8rem; color: var(--ink); }
  .tag {
    font-family: var(--font-utility); font-size: 0.6rem; text-transform: none;
    letter-spacing: 0.02em; color: var(--foil); border: 1px solid var(--foil);
    border-radius: 3px; padding: 0.05rem 0.35rem; margin-left: 0.4rem;
  }

  input[type='range'] {
    -webkit-appearance: none; appearance: none;
    width: 100%; height: 2px; background: var(--hairline); border-radius: 2px; cursor: pointer;
  }
  input[type='range']::-webkit-slider-thumb {
    -webkit-appearance: none; appearance: none;
    width: 18px; height: 18px; border-radius: 50%;
    background: var(--foil); border: 2px solid var(--paper); box-shadow: 0 1px 4px rgba(0,0,0,0.25);
  }
  input[type='range']::-moz-range-thumb {
    width: 18px; height: 18px; border-radius: 50%; background: var(--foil); border: 2px solid var(--paper);
  }

  .curs-row, .curs-row.folio { display: flex; justify-content: center; align-items: center; gap: 0.5rem; }
  .curs-row { text-transform: none; }
  input[type='checkbox'] { width: 1rem; height: 1rem; accent-color: var(--foil); cursor: pointer; }

  .presets { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.6rem; align-items: center; padding-top: 0.25rem; }
  .preset {
    cursor: pointer; background: none; border: 1px solid var(--hairline); border-radius: 4px;
    padding: 0.4rem 0.85rem; color: var(--ink-muted);
  }
  .preset:hover { border-color: var(--foil); color: var(--foil); }

  .hint { display: block; color: var(--ink-muted); font-size: 0.7rem; letter-spacing: 0.02em; text-transform: none; line-height: 1.5; }

  .reset {
    justify-self: center; cursor: pointer; background: none;
    border: 1px solid var(--ink); border-radius: 4px; padding: 0.55rem 1.1rem; color: var(--ink);
  }
  .reset:hover { border-color: var(--foil); color: var(--foil); }

  .prose { margin-top: 3rem; margin-inline: auto; }
  .prose h2 { text-align: center; }
  .prose code { font-family: var(--font-utility); font-size: 0.85em; background: #1c2030; padding: 0.1em 0.35em; border-radius: 3px; }
</style>

<script>
  const specimen = document.getElementById('specimen');
  const wght = document.getElementById('wght');
  const casl = document.getElementById('casl');
  const mono = document.getElementById('mono');
  const slnt = document.getElementById('slnt');
  const crsv = document.getElementById('crsv');
  const reset = document.getElementById('reset');
  const outW = document.getElementById('out-wght');
  const outC = document.getElementById('out-casl');
  const outM = document.getElementById('out-mono');
  const outS = document.getElementById('out-slnt');

  const DEFAULTS = { wght: 400, casl: 0, mono: 0, slnt: 0 };

  function apply() {
    // CASL and MONO axes run 0..1 in the font; sliders show 0..100 for feel
    const casl01 = (casl.value / 100).toFixed(3);
    const mono01 = (mono.value / 100).toFixed(3);
    specimen.style.setProperty(
      'font-variation-settings',
      `'wght' ${wght.value}, 'CASL' ${casl01}, 'MONO' ${mono01}, 'slnt' ${slnt.value}, 'CRSV' ${crsv.checked ? 1 : 0}`
    );
    outW.textContent = wght.value;
    outC.textContent = casl.value;
    outM.textContent = mono.value;
    outS.textContent = slnt.value;
  }

  [wght, casl, mono, slnt].forEach((el) => el.addEventListener('input', apply));
  crsv.addEventListener('change', apply);

  document.querySelectorAll('.preset').forEach((btn) => {
    btn.addEventListener('click', () => {
      wght.value = btn.dataset.w;
      casl.value = btn.dataset.c;
      mono.value = btn.dataset.m;
      slnt.value = btn.dataset.s;
      apply();
    });
  });

  reset.addEventListener('click', () => {
    wght.value = DEFAULTS.wght; casl.value = DEFAULTS.casl;
    mono.value = DEFAULTS.mono; slnt.value = DEFAULTS.slnt; crsv.checked = false;
    apply();
  });

  // ---- share (carries whatever the visitor typed) ----
  const nativeBtn = document.getElementById('native-share');
  if (navigator.share && nativeBtn) nativeBtn.hidden = false;

  document.querySelectorAll('.share-btn').forEach((b) => {
    b.addEventListener('click', async () => {
      const typed = (specimen.textContent || '').trim().slice(0, 80);
      const text = typed
        ? `"${typed}" — played with variable font axes on vincentvi.me`
        : 'A variable font playground on vincentvi.me';
      const url = window.location.href;
      const eu = encodeURIComponent(url);
      const et = encodeURIComponent(text);
      const net = b.dataset.net;
      if (net === 'x') {
        window.open(`https://twitter.com/intent/tweet?text=${et}&url=${eu}`, '_blank', 'noopener');
      } else if (net === 'linkedin') {
        window.open(`https://www.linkedin.com/sharing/share-offsite/?url=${eu}`, '_blank', 'noopener');
      } else if (net === 'copy') {
        try {
          await navigator.clipboard.writeText(url);
          const old = b.textContent; b.textContent = 'Copied ✓';
          setTimeout(() => { b.textContent = old; }, 1600);
        } catch { /* blocked */ }
      } else if (net === 'native') {
        try { await navigator.share({ text, url, title: document.title }); } catch {}
      }
    });
  });

  apply();
</script>
