---
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkCard from '../components/WorkCard.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../config';

const work = (await getCollection('portfolio'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---
<BaseLayout>
  <section class="hero">
    <p class="folio">Designer · Letterer · Ho Chi Minh City</p>
    <h1>Letterforms, books, and the spaces between them.</h1>
    <p class="lede">
      I'm {SITE.name} — a graphic designer working in typography, hand-lettering,
      and book design. I draw letters, set pages, and occasionally write about
      how it all gets made.
    </p>
    <p><a href="/portfolio/">See the work</a> · <a href="/contact/">Start a project</a></p>
  </section>

  <hr />

  <section>
    <p class="folio">Selected work</p>
    <div class="grid">
      {work.map((item) => (
        <WorkCard
          href={`/portfolio/${item.id}/`}
          title={item.data.title}
          category={item.data.category}
          year={item.data.year}
          cover={item.data.cover}
        />
      ))}
    </div>
    <p class="more"><a href="/portfolio/">All projects →</a></p>
  </section>

  <hr />

  <section>
    <p class="folio">From the blog</p>
    <ul class="postlist">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}/`}>{post.data.title}</a>
          <span class="folio">{post.data.pubDate.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .hero { padding-block: 3rem 1rem; }
  .lede { font-size: var(--step-1); line-height: 1.5; color: var(--ink-muted); }
  .grid {
    display: grid; gap: 3rem 2.25rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
  .more { margin-top: 2rem; }
  .postlist { list-style: none; padding: 0; display: grid; gap: 0.75rem; }
  .postlist li { display: flex; gap: 1rem; align-items: baseline; justify-content: space-between; max-width: var(--measure); }
</style>
