---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title="Blog" description="Notes on typography, lettering, book design, and learning to build for the web.">
  <p class="folio">Blog</p>
  <h1>Notes</h1>
  <ul class="posts">
    {posts.map((post) => (
      <li>
        <p class="folio">{post.data.pubDate.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
        <h2><a href={`/blog/${post.id}/`}>{post.data.title}</a></h2>
        <p>{post.data.description}</p>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .posts { list-style: none; padding: 0; display: grid; gap: 2.5rem; margin-top: 2rem; }
  .posts h2 { margin: 0.25rem 0 0.35rem; }
  .posts a { color: var(--ink); text-decoration: none; }
  .posts a:hover { color: var(--cloth); }
  .posts p { color: var(--ink-muted); margin: 0; }
</style>
