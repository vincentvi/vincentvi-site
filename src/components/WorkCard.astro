---
/**
 * Portfolio card — "ink to color" press reveal.
 * CSS-only (SEO/perf safe): no JS, lazy images, fixed aspect ratio (no CLS),
 * reduced-motion respected via global.css.
 */
interface Props {
  href: string;
  title: string;
  category: string;
  year: number;
  cover: string;
  summary?: string;
}
const { href, title, category, year, cover, summary } = Astro.props;
---
<a class="work-card" href={href}>
  <span class="spine folio">{category}</span>
  <figure>
    <img
      src={cover}
      alt={`${title} — ${category}`}
      width="800"
      height="600"
      loading="lazy"
      decoding="async"
    />
  </figure>
  <div class="meta">
    <h3>{title}</h3>
    {summary && <p class="summary">{summary}</p>}
    <p class="folio year">{year}</p>
  </div>
</a>

<style>
  .work-card {
    position: relative;
    display: grid;
    grid-template-columns: 1.6rem 1fr;
    text-decoration: none;
    color: var(--ink);
    transition: transform 0.35s ease;
  }

  /* book-spine category label */
  .spine {
    writing-mode: vertical-rl;
    rotate: 180deg;
    align-self: stretch;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-block: 0.5rem;
    border-right: 1px solid var(--hairline);
    margin-right: 0.75rem;
    transition: color 0.35s ease, border-color 0.35s ease;
  }

  figure {
    grid-column: 2;
    margin: 0;
    overflow: hidden;
    border: 1px solid var(--hairline);
    background: var(--ink);
    aspect-ratio: 4 / 3;
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* at rest: inked-down, waiting on the press */
    filter: saturate(0.12) contrast(1.03) brightness(0.97);
    transition: filter 0.5s ease, transform 0.6s ease;
  }

  .meta { grid-column: 2; padding-top: 0.85rem; }
  h3 {
    margin: 0 0 0.3rem;
    font-size: var(--step-1);
    /* underline draws in from the left on hover */
    background-image: linear-gradient(var(--foil), var(--foil));
    background-repeat: no-repeat;
    background-position: 0 100%;
    background-size: 0% 2px;
    transition: background-size 0.4s ease;
    display: inline;
    padding-bottom: 2px;
  }
  .summary { color: var(--ink-muted); margin: 0.35rem 0 0.45rem; font-size: var(--step--1); line-height: 1.55; }
  .year { margin: 0.35rem 0 0; }

  /* ---------- hover: the press run ---------- */
  @media (hover: hover) {
    .work-card:hover { transform: translateY(-4px); }
    .work-card:hover img {
      filter: saturate(1) contrast(1) brightness(1);
      transform: scale(1.045);
    }
    .work-card:hover h3 { background-size: 100% 2px; }
    .work-card:hover .spine { color: var(--foil); border-color: var(--foil); }
  }
  .work-card:focus-visible { outline: 2px solid var(--cloth); outline-offset: 4px; }
  .work-card:focus-visible img { filter: saturate(1); }
</style>
