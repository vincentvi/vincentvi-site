---
import { SITE, SOCIALS } from '../config';
const year = new Date().getFullYear();
---
<footer>
  <div class="inner">
    <p class="folio">{SITE.name} · Ho Chi Minh City · {year}</p>
    <nav aria-label="Social links">
      {SOCIALS.map((s) => (
        <a href={s.url} rel="me noopener" target="_blank">{s.label}</a>
      ))}
    </nav>
    <p class="colophon">
      Set in Fraunces &amp; Newsreader. Built with Astro, served by Cloudflare.
    </p>
  </div>
</footer>

<style>
  footer { border-top: 1px solid var(--hairline); margin-top: 4rem; }
  .inner {
    max-width: 72rem; margin-inline: auto;
    padding: 2rem var(--gutter) 2.5rem;
    display: grid; gap: 0.75rem;
  }
  nav { display: flex; gap: 1.25rem; flex-wrap: wrap; }
  nav a {
    font-family: var(--font-utility); font-size: 0.78rem;
    letter-spacing: 0.08em; text-transform: uppercase;
  }
  .colophon { font-size: var(--step--1); color: var(--ink-muted); font-style: italic; margin: 0; }
  .folio { margin: 0; }
</style>
