---
import '@fontsource-variable/fraunces/opsz.css';
import '@fontsource-variable/newsreader/opsz.css';
import '@fontsource-variable/newsreader/opsz-italic.css';
import '../styles/global.css';
import { SITE, SOCIALS } from '../config';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  /** set for blog posts / portfolio pieces */
  ogType?: 'website' | 'article';
  /** absolute or /public path to a share image */
  ogImage?: string;
}

const {
  title,
  description = SITE.description,
  ogType = 'website',
  ogImage = SITE.defaultOgImage,
} = Astro.props;

const pageTitle = title ? `${title} — ${SITE.name}` : SITE.title;
const canonical = new URL(Astro.url.pathname, SITE.url).href;
const ogImageAbs = ogImage ? new URL(ogImage, SITE.url).href : undefined;

// Structured data: a Person entity for the site, so search engines can
// connect the name, role, and your verified profiles. sameAs drops any
// placeholder ("#") links.
const sameAs = SOCIALS.map((s) => s.url).filter((u) => u && u !== '#');
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.author,
  url: SITE.url,
  jobTitle: SITE.jobTitle,
  description: SITE.description,
  image: ogImageAbs,
  ...(sameAs.length ? { sameAs } : {}),
};
---
<!doctype html>
<html lang={SITE.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" sizes="512x512" />
    <link rel="icon" href="/favicon.ico" sizes="16x16 32x32 48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />
    {SITE.googleSiteVerification && (
      <meta name="google-site-verification" content={SITE.googleSiteVerification} />
    )}

    <!-- Open Graph / social sharing -->
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImageAbs && <meta property="og:image" content={ogImageAbs} />}
    <meta name="twitter:card" content={ogImageAbs ? 'summary_large_image' : 'summary'} />
    {ogImageAbs && <meta name="twitter:image" content={ogImageAbs} />}

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
